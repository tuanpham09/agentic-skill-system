{
  "name": "agentic-skill-system",
  "private": true,
  "version": "1.0.0",
  "description": "Agentic Skill System — AI coding agent framework",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "lint:fix": "eslint 'packages/*/src/**/*.ts' --fix",
    "typecheck": "pnpm -r --filter './packages/*' typecheck",
    "dev": "pnpm -r --parallel --filter './packages/*' dev",
    "clean": "pnpm -r --filter './packages/*' clean && rm -rf node_modules",
    "skill:validate-all": "node packages/cli/dist/index.js skill validate-all 2>/dev/null || echo 'Build CLI first'"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.3.0",
    "@typescript-eslint/parser": "^7.3.0",
    "@vitest/coverage-v8": "^1.4.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.2",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
